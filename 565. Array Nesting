class Solution:
    def arrayNesting(self, nums: List[int]) -> int:
        max_length = 0
        for i in range(len(nums)):
            if nums[i] != -1:
                current_length = 0
                curr = i
                while nums[curr] != -1:
                    next_node = nums[curr]
                    nums[curr] = -1 
                    curr = next_node
                    current_length += 1
                
                max_length = max(max_length, current_length)            
        return max_length
