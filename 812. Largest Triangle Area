class Solution {
    public double largestTriangleArea(int[][] points) {
        double maxarea = 0.0;
        int n = points.length;
        for ( int i = 0; i< n ; i++){
            for (int j = i; j<n; j++){
                for(int k = j; k< n; k++){
                    maxarea = Math.max(maxarea , area(points[i], points[j] , points[k]));
                }
            }
        }
        return maxarea ;
    }
public double area(int[] p1, int[] p2, int[] p3){
        int x1 = p1[0], y1 = p1[1];
        int x2 = p2[0], y2 = p2[1];
        int x3 = p3[0], y3 = p3[1];
        return Math.abs(x1*(y2-y3)+x2*(y3-y1)+ x3*(y1-y2))/2.0;
    }
}
