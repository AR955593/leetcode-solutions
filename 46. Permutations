class Solution:
    def permute(self, nums: List[int]) -> List[List[int]]:
        res = []
        u = [False] * len(nums) 
        def bt(path):
            if len(path) == len(nums):
                res.append(path[:])
                return
            for i in range(len(nums)):
                if not u[i]:
                    u[i] = True
                    path.append(nums[i])
                    bt(path)
                    path.pop() 
                    u[i] = False
        bt([])
        return res
