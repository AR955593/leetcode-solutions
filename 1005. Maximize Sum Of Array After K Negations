class Solution:
    def largestSumAfterKNegations(self, nums: List[int], k: int) -> int:
        nums.sort()
        for i in range ( len(nums)):
            if nums[i]<0 and k>0:
                nums[i] = -nums[i]
                k -= 1
        total = sum(nums)
        mins = min(nums)
        if k%2 == 1:
            total -= 2*mins
        return total            
