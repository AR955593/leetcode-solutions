class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        max_pro=0 
        minprice = prices[0]
        for i in prices:
            if i<minprice:
                minprice = i
            else :
                profit = i - minprice
                max_pro = max(max_pro,profit) 
        return max_pro    
        
